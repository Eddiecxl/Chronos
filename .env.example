PORT=3001
# Render API settings
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=chronos
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-project.vercel.app
SESSION_SECRET=replace-with-a-long-random-secret-before-production

# Optional: set all three values to provision the first admin account.
# There is intentionally no default production admin account.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PIN=

# Vercel frontend setting (use your Render service URL)
VITE_API_URL=https://your-api.onrender.com
